# GoHighLevel Integration
GHL_WEBHOOK_URL=                     # Server-side: Default GoHighLevel webhook URL
GHL_CONTACT_WEBHOOK_URL=             # Server-side: GoHighLevel webhook URL for contact forms
GHL_REFERRAL_WEBHOOK_URL=            # Server-side: GoHighLevel webhook URL for referral concierge forms
GHL_CAREFINDER_WEBHOOK_URL=          # Server-side: GoHighLevel webhook URL for care finder forms
NEXT_PUBLIC_GHL_FORM_ID=             # Public: GoHighLevel form ID (if using embedded forms)
NEXT_PUBLIC_GHL_EMBED_CHAT_ID=       # Public: GoHighLevel AI chat widget embed ID
NEXT_PUBLIC_GHL_EMBED_VOICE_ID=      # Public: GoHighLevel AI voice assistant embed ID

# Analytics
NEXT_PUBLIC_GA_ID=                   # Public: Google Analytics 4 measurement ID (G-XXXXXXXXXX)
NEXT_PUBLIC_GSC_VERIFICATION=        # Public: Google Search Console verification code

# Site
NEXT_PUBLIC_SITE_URL=https://gentlecarenursing.com.au
